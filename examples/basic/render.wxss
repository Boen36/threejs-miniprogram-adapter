/* 基础渲染示例样式 */
.container {
  position: relative;
  width: 100vw;
  height: 100vh;
  background: #000;
}

.webgl-canvas {
  display: block;
  width: 100%;
  height: 100%;
}

.info {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  color: #fff;
  font-size: 16px;
}
